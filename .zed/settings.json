{
  "languages": {
    "Rust": {
      "format_on_save": "on"
    }
  },
  "lsp": {
    "rust-analyzer": {
      "initialization_options": {
        "cargo": {
          "target": "riscv32imc-unknown-none-elf",
          "features": ["ch32v003f4p6", "system-flash"]
        },
        "check": {
          "command": "clippy",
          "allTargets": false
        }
      }
    }
  }
}
